<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AgendaActivity">
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar"/>

    <!-- Título -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Complete your day"
        android:textColor="@color/colorBlack"
        android:textSize="24sp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Botón reproducir -->
    <!-- Botón reproducir (centrado verticalmente en zona superior) -->
    <ImageButton
        android:id="@+id/reproducir"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/play"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/endSpacer"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/reproducirTexto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play"
        android:textColor="@color/colorBlack"
        android:textSize="20sp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/reproducir"
        app:layout_constraintEnd_toEndOf="@id/reproducir"
        app:layout_constraintStart_toStartOf="@id/reproducir"/>


    <!-- Lista seleccionados -->
    <FrameLayout
        android:id="@+id/recyclerContainer"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/dividerVertical"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />


    </FrameLayout>
    <!-- 🔵 LÍNEA AZUL GRUESA -->
    <View
        android:id="@+id/dividerBottom"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:background="@color/colorPurple"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/recyclerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔵 LÍNEA VERTICAL (entre los dos dividers) -->
    <View
        android:id="@+id/dividerVertical"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/colorPurple"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/rightSpacer"/>

    <View
        android:id="@+id/rightSpacer"
        android:layout_width="20dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/reproducir"/>
    <View
        android:id="@+id/endSpacer"
        android:layout_width="30dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- GRID DE PICTOGRAMAS -->
    <GridLayout
        android:id="@+id/pictogramasLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:columnCount="9"
        android:alignmentMode="alignBounds"
        android:gravity="center"
        android:useDefaultMargins="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/dividerBottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- Contenedor oculto -->
    <LinearLayout
        android:id="@+id/containerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>