<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AgendaActivity">
    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar"/>

    <LinearLayout
        android:id="@+id/helpContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnHelp"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@drawable/help"
            android:scaleType="fitXY"
            android:padding="0dp"
            android:contentDescription="Help"/>

        <TextView
            android:id="@+id/helpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HELP"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/colorPurple"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/loadingBox"
        android:layout_width="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_height="250dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="40dp"
        android:padding="40dp"
        android:background="@drawable/bg_dialog_rounded"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/instruction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete the sequence of actions!"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="32sp"
            android:gravity="center"
            android:textAlignment="center"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="16dp">

            <Button
                android:id="@+id/sayitagain"
                android:layout_height="48dp"
                android:layout_width="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="SAY IT AGAIN"
                android:background="@drawable/btn_rounded_t"
                android:textColor="@color/colorBlack"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:padding="12dp"/>

            <Button
                android:id="@+id/skip"
                android:layout_height="48dp"
                android:layout_width="wrap_content"
                android:layout_marginStart="8dp"
                android:text="SKIP"
                android:background="@drawable/btn_rounded_t"
                android:textColor="@color/colorBlack"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="18sp"
                android:padding="12dp"/>

        </LinearLayout>


    </LinearLayout>

    <!-- Título -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Review what you did yesterday"
        android:textColor="@color/colorBlack"
        android:textSize="24sp"
        android:padding="10dp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="@id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Botón reproducir -->
    <!-- Botón reproducir (centrado verticalmente en zona superior) -->
    <ImageButton
        android:id="@+id/reproducir"
        android:visibility="invisible"

        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/play"
        android:scaleType="centerInside"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/endSpacer"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:id="@+id/reproducirTexto"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play"
        android:textColor="@color/colorBlack"
        android:textSize="20sp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/reproducir"
        app:layout_constraintEnd_toEndOf="@id/reproducir"
        app:layout_constraintStart_toStartOf="@id/reproducir"/>


    <!-- Lista seleccionados -->
    <FrameLayout
        android:id="@+id/recyclerContainer"
        android:layout_width="0dp"
        android:layout_height="180dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/dividerVertical"
        app:layout_constraintBottom_toTopOf="@id/dividerBottom">

        <!-- RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:visibility="invisible"

            android:clipToPadding="false"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />


    </FrameLayout>
    <!-- 🔵 LÍNEA AZUL GRUESA -->
    <View
        android:id="@+id/dividerBottom"
        android:visibility="invisible"
        android:layout_width="0dp"
        android:layout_height="14dp"
        android:background="@color/colorPurple"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/recyclerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔵 LÍNEA VERTICAL (entre los dos dividers) -->
    <View
        android:id="@+id/dividerVertical"
        android:visibility="invisible"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="@color/colorPurple"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/rightSpacer"/>

    <View
        android:id="@+id/rightSpacer"
        android:layout_width="20dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toStartOf="@id/reproducir"/>
    <View
        android:id="@+id/endSpacer"
        android:layout_width="30dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="@id/dividerBottom"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- GRID DE PICTOGRAMAS -->
    <GridLayout
        android:id="@+id/pictogramasLayout"
        android:layout_width="match_parent"
        android:visibility="invisible"
        android:layout_height="0dp"
        android:columnCount="9"
        android:alignmentMode="alignBounds"
        android:gravity="center"
        android:useDefaultMargins="true"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/dividerBottom"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <!-- Contenedor oculto -->
    <LinearLayout
        android:id="@+id/containerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>