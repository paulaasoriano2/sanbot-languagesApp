<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="32dp"
    android:gravity="center"
    android:background="#F0F0F0">

    <TextView
        android:id="@+id/feedbackTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:gravity="center"
        android:text="ANSWER"
        android:textAlignment="center"
        android:textColor="@color/colorPurple"
        android:textSize="52sp"
        android:textStyle="bold"/>

    <TextView
        android:id="@+id/feedbackSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:gravity="center"
        android:text="You almost got it, next time you’ll definitely get it!"
        android:textAlignment="center"
        android:textColor="#8A8A8A"
        android:textSize="28sp"
        android:textStyle="bold"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/imgRespuesta"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_margin="20dp"
            android:src="@drawable/apple"
            android:layout_gravity="center"
            android:contentDescription="Image"
            android:background="#FFFFFF"
            android:padding="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Apple"
            android:textSize="36sp"
            android:textColor="#222222"
            android:textAlignment="center"
            android:gravity="center"
            android:id="@+id/textoRespuesta"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Do you want to play with other word?"
        android:textSize="26sp"
        android:layout_margin="20dp"
        android:textColor="#8A8A8A"
        android:textAlignment="center"
        android:gravity="center"
        android:id="@+id/jugarDeNuevo"
        android:textStyle="bold"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnCancel"
            android:text="No"
            android:layout_width="140dp"
            android:layout_height="52dp"
            android:backgroundTint="#F8B4B4"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnAccept"
            android:text="Yes"
            android:layout_marginStart="12dp"
            android:layout_width="140dp"
            android:layout_height="52dp"
            android:backgroundTint="#BFE6C3"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textAllCaps="false"/>
    </LinearLayout>

</LinearLayout>