<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".ColoresActivity">

    <!-- ================= FILA 1 ================= -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- RED -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgred"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/red"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="RED"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <!-- BLUE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgblue"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/blue"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="BLUE"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <!-- YELLOW -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgyellow"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/yellow"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="YELLOW"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <!-- GREEN -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imggreen"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"

                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/green"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="GREEN"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ================= FILA 2 ================= -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp">

        <!-- ORANGE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgorange"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/orange"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="ORANGE"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgpurple"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/purple"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="PURPLE"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgblack"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/black"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="BLACK"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/imgwhite"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/colores"
                android:scaleType="centerInside"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <Button
                android:id="@+id/white"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:text="WHITE"
                android:background="@drawable/button_rounded"
                android:textColor="@color/colorWhite"/>
        </LinearLayout>


    </LinearLayout>

</LinearLayout>